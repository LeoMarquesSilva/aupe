# Supabase (frontend)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_KEY=

# --- App Meta "insyt" (Facebook Login + Instagram Graph) ---
# No painel: developers.facebook.com → Seu app → Configurações → Básico → ID do aplicativo e Chave secreta
REACT_APP_INSTAGRAM_APP_ID=
# (opcional, se quiser separar nomes) REACT_APP_FACEBOOK_APP_ID=

# Deve ser IGUAL à URI cadastrada em: App → Produtos → Facebook Login → Configurações → URIs de redirecionamento OAuth válidos
# Ex.: https://SEU-DOMINIO.vercel.app/callback  e  http://localhost:3000/callback (dev)
REACT_APP_INSTAGRAM_REDIRECT_URI=
# REACT_APP_FACEBOOK_REDIRECT_URI=

# Chave secreta do app (Configurações → Básico). Usada no front para trocar code→token no fluxo atual.
REACT_APP_FACEBOOK_APP_SECRET=

# Edge Functions (opcional — instagram-oauth-exchange era para Business Login Instagram)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=https://seu-dominio.com/callback
# INSTAGRAM_REFRESH_CRON_SECRET=gerar-string-segura

# Servidor Express opcional (server/routes/instagram.js)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=
