# Supabase (frontend)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_KEY=

# Instagram Business Login — mesmo App ID do painel Meta (Instagram > API setup with Instagram login)
REACT_APP_INSTAGRAM_APP_ID=
# Deve coincidir exatamente com "OAuth redirect URIs" no Meta (ex.: https://seu-dominio.com/callback)
REACT_APP_INSTAGRAM_REDIRECT_URI=

# Edge Functions (definir no Dashboard Supabase → Edge Functions → Secrets)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=https://seu-dominio.com/callback
# INSTAGRAM_REFRESH_CRON_SECRET=gerar-string-segura

# Servidor Express opcional (server/routes/instagram.js)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=
