# Supabase (frontend)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_KEY=

# Facebook Login (Graph API) — mesmo App no Meta for Developers
# Adicione a URI de redirecionamento em: App > Facebook Login > Configurações > URIs de redirecionamento OAuth válidos
REACT_APP_INSTAGRAM_APP_ID=
# ou explicitamente:
# REACT_APP_FACEBOOK_APP_ID=

# URI exata cadastrada no Meta (ex.: https://seu-dominio.com/callback)
REACT_APP_INSTAGRAM_REDIRECT_URI=
# ou:
# REACT_APP_FACEBOOK_REDIRECT_URI=

# App Secret — necessário no browser para trocar code→token (fluxo legado até App Review)
# Não commite o valor real. Configure na Vercel como variável de ambiente.
REACT_APP_FACEBOOK_APP_SECRET=

# Edge Functions (opcional — instagram-oauth-exchange era para Business Login Instagram)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=https://seu-dominio.com/callback
# INSTAGRAM_REFRESH_CRON_SECRET=gerar-string-segura

# Servidor Express opcional (server/routes/instagram.js)
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=
# INSTAGRAM_REDIRECT_URI=
