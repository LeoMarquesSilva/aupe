# Supabase (frontend)
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_KEY=

# --- Facebook Login (único fluxo OAuth) — depois acedemos ao IG via Graph (conta comercial ligada à Página) ---
# developers.facebook.com → App → Configurações → Básico → ID do aplicativo e Chave secreta
REACT_APP_FACEBOOK_APP_ID=
REACT_APP_FACEBOOK_REDIRECT_URI=http://localhost:3000/callback

# Alias legado (o código ainda aceita; prefira os nomes FACEBOOK_* acima)
# REACT_APP_INSTAGRAM_APP_ID=
# REACT_APP_INSTAGRAM_REDIRECT_URI=http://localhost:3000/callback

# A redirect_uri tem de coincidir com: App → Facebook Login → URIs de redirecionamento OAuth válidos

# Secret só no servidor — usado por POST /api/facebook-oauth-token (não vai no bundle do browser)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Vercel: REACT_APP_* no build; FACEBOOK_APP_ID + FACEBOOK_APP_SECRET nas env vars do projeto ---

# Legado / emergência: secret no bundle (evitar em produção)
# REACT_APP_FACEBOOK_APP_SECRET=
#
# CRA não sobrescreve env já definida no terminal com string vazia — npm run dev usa scripts/cra-dev-start.js
# para limpar REACT_APP_* secret vazio antes do react-scripts.

# Edge Functions / Express antigos (só se ainda usares)
# INSTAGRAM_REFRESH_CRON_SECRET=
